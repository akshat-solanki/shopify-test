{% liquid
  assign instance_id = block.settings.instance_id | strip
  assign showcase_collection = block.settings.collection
  assign heading = block.settings.heading | strip
  assign subheading = block.settings.subheading | strip
  assign products_to_show = block.settings.products_to_show
  assign accent_color = block.settings.accent_color | default: '#111827'
  assign cta_label = block.settings.cta_label | default: 'Shop now'
  assign layout_mode = block.settings.layout
%}

<section
  class="vypari-showcase vypari-showcase--{{ layout_mode }}"
  style="--vypari-accent: {{ accent_color }};"
  data-vypari-instance-id="{{ instance_id }}"
  data-vypari-proxy-url="/apps/vypari-showcase/instances"
  data-vypari-shop="{{ shop.permanent_domain | default: shop.domain }}"
  {{ block.shopify_attributes }}
>
  <div class="vypari-showcase__shell">
    <div class="vypari-showcase__header">
      <div>
        {% if heading != blank %}
          <h2 class="vypari-showcase__heading">{{ heading }}</h2>
        {% endif %}
        {% if subheading != blank %}
          <p class="vypari-showcase__subheading">{{ subheading }}</p>
        {% endif %}
      </div>

      {% if layout_mode == 'carousel' %}
        <div class="vypari-showcase__controls" aria-label="Product showcase navigation">
          <button type="button" class="vypari-showcase__control" data-vypari-prev aria-label="Scroll previous products">
            <span aria-hidden="true">‹</span>
          </button>
          <button type="button" class="vypari-showcase__control" data-vypari-next aria-label="Scroll next products">
            <span aria-hidden="true">›</span>
          </button>
        </div>
      {% endif %}
    </div>

    {% if instance_id != blank %}
      <div class="vypari-showcase__runtime" data-vypari-runtime>
        <div class="vypari-showcase__runtime-state">Loading synced showcase instance...</div>
      </div>
    {% elsif showcase_collection != blank and showcase_collection.products_count > 0 %}
      <div class="vypari-showcase__track" data-vypari-track>
        {% for product in showcase_collection.products limit: products_to_show %}
          {% liquid
            assign featured_image = product.featured_media.preview_image | default: product.featured_image
            assign secondary_image = product.images[1]
            assign compare_at_price = product.compare_at_price
            assign current_price = product.price
            assign has_discount = false
            if compare_at_price > current_price
              assign has_discount = true
            endif
          %}

          <article class="vypari-showcase__card">
            <a href="{{ product.url }}" class="vypari-showcase__media-link">
              <div class="vypari-showcase__media">
                {% if featured_image != blank %}
                  {{
                    featured_image
                    | image_url: width: 900
                    | image_tag:
                      class: 'vypari-showcase__image vypari-showcase__image--primary',
                      loading: 'lazy',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 88vw',
                      alt: product.title
                  }}
                {% else %}
                  <div class="vypari-showcase__image vypari-showcase__image--placeholder"></div>
                {% endif %}

                {% if block.settings.show_secondary_image and secondary_image != blank %}
                  {{
                    secondary_image
                    | image_url: width: 900
                    | image_tag:
                      class: 'vypari-showcase__image vypari-showcase__image--secondary',
                      loading: 'lazy',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 88vw',
                      alt: product.title
                  }}
                {% endif %}

                {% if block.settings.show_badges %}
                  <div class="vypari-showcase__badges">
                    {% if has_discount %}
                      <span class="vypari-showcase__badge vypari-showcase__badge--sale">Sale</span>
                    {% endif %}
                    {% if product.available == false %}
                      <span class="vypari-showcase__badge vypari-showcase__badge--muted">Sold out</span>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </a>

            <div class="vypari-showcase__content">
              {% if block.settings.show_vendor and product.vendor != blank %}
                <div class="vypari-showcase__eyebrow">{{ product.vendor }}</div>
              {% endif %}

              <h3 class="vypari-showcase__title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              {% if block.settings.show_price %}
                <div class="vypari-showcase__pricing">
                  <span class="vypari-showcase__price">{{ current_price | money }}</span>
                  {% if has_discount %}
                    <span class="vypari-showcase__compare">{{ compare_at_price | money }}</span>
                  {% endif %}
                </div>
              {% endif %}

              <div class="vypari-showcase__footer">
                <a class="vypari-showcase__cta" href="{{ product.url }}">{{ cta_label }}</a>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
    {% elsif request.design_mode %}
      <div class="vypari-showcase__empty">
        <h3>Add a collection to preview the showcase</h3>
        <p>Select a collection in the block settings, then drag this app block anywhere the section allows.</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Vypari showcase",
  "target": "section",
  "stylesheet": "vypari-product-showcase.css",
  "javascript": "vypari-product-showcase.js",
  "settings": [
    {
      "type": "text",
      "id": "instance_id",
      "label": "Instance ID",
      "info": "Paste a showcase instance ID from the Vypari app to load app-owned runtime settings through the app proxy."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A drag-and-drop product showcase powered by your Shopify theme editor."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "grid",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" },
        { "value": "spotlight", "label": "Spotlight" }
      ]
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#111827"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Show sale and stock badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show hover image",
      "default": true
    }
  ]
}
{% endschema %}
